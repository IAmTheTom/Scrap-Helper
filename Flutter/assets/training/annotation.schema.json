{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "image",
    "width",
    "height",
    "objects"
  ],
  "properties": {
    "image": {
      "type": "string"
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "bbox"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "bbox": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "number"
            }
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hazards": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}